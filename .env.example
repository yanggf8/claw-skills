# claw-skills environment variables
# Copy to ~/.nullclaw/.env or ~/.openclaw/.env and fill in real values.
# NEVER commit real credentials to git.

# ── Turso (persona registry + history) ───────────────────────────────────────
PERSONA_REGISTRY_DB_URL=libsql://your-db-name.turso.io
PERSONA_REGISTRY_DB_TOKEN=your-turso-auth-token

# ── Persona Webapp (CF Workers) ───────────────────────────────────────────────
# Used by skill --mode preview-pending to write back via CF Workers API
PERSONA_API_URL=https://persona-webapp.yanggf.workers.dev
PERSONA_SERVICE_TOKEN=your-service-token   # must match CF Workers Secret SERVICE_TOKEN

# ── CF Workers Secrets (set via: wrangler secret put <KEY>) ──────────────────
# JWT_SECRET=<random 32-byte hex>          # wrangler secret put JWT_SECRET
# SERVICE_TOKEN=<random 32-byte hex>       # wrangler secret put SERVICE_TOKEN
# GOOGLE_CLIENT_ID=<from Google Console>   # wrangler secret put GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_SECRET=<...>              # wrangler secret put GOOGLE_CLIENT_SECRET
# GITHUB_CLIENT_ID=<from GitHub Settings> # wrangler secret put GITHUB_CLIENT_ID
# GITHUB_CLIENT_SECRET=<...>             # wrangler secret put GITHUB_CLIENT_SECRET
# TURSO_URL=<same as PERSONA_REGISTRY_DB_URL>  # wrangler secret put TURSO_URL
# TURSO_TOKEN=<same as PERSONA_REGISTRY_DB_TOKEN> # wrangler secret put TURSO_TOKEN

# ── Taiwan Weather ────────────────────────────────────────────────────────────
CWA_API_KEY=your-cwa-api-key

# ── Telegram ──────────────────────────────────────────────────────────────────
# Managed via ~/.nullclaw/config.json or ~/.openclaw/openclaw.json
# See README.md for schema details
